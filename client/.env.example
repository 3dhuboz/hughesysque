# ═══════════════════════════════════════════════════════════════
# WHITE-LABEL FOOD TRUCK APP — Environment Variables
# Set these in Vercel → Project Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Firebase (create project at https://console.firebase.google.com) ──
REACT_APP_FIREBASE_API_KEY=AIzaSy...
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Brand / White-label ──
REACT_APP_CLIENT_MODE=true
REACT_APP_ENABLED_APPS=foodtruck
REACT_APP_BRAND_NAME=Hughesys Que
REACT_APP_BRAND_TAGLINE=Quality Street Food
REACT_APP_PRIMARY_COLOR=#f59e0b

# ── Admin ──
# Email address that will be auto-assigned the 'admin' role on first login
REACT_APP_ADMIN_EMAIL=hugheseysbbq2021@gmail.com
