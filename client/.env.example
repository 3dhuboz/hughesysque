# ═══════════════════════════════════════════════════════════════
# HUGHESYS QUE — Environment Variables
# Set these in Cloudflare Pages → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Clerk (auth) ──
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── OpenRouter (AI) ──
VITE_OPENROUTER_API_KEY=...
OPENROUTER_API_KEY=...

# ── Resend (email) ──
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@hugheseysque.au
RESEND_FROM_NAME=Hughesys Que

# ── Branding ──
VITE_BRAND_NAME=Hughesys Que
VITE_BRAND_TAGLINE=Quality Street Food
VITE_PRIMARY_COLOR=#f59e0b

# ── MessageBird (SMS — optional) ──
MESSAGEBIRD_API_KEY=...
MESSAGEBIRD_ORIGINATOR=HughesysQue

# ── Facebook (social — optional) ──
VITE_FACEBOOK_APP_ID=...
FACEBOOK_APP_SECRET=...

# ── Square (payments — optional) ──
# Set these in the Admin > Settings UI instead
