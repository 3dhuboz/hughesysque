# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/pennywise-it

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SiteGround API Configuration
SITEGROUND_API_URL=https://api.siteground.com
SITEGROUND_API_TOKEN=your-siteground-api-token

# Google OAuth (for social login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Square Payments (REQUIRED for collecting money)
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_ENVIRONMENT=production

# Admin Setup
ADMIN_EMAIL=admin@pennywiseit.com.au
ADMIN_PASSWORD=change-this-to-a-strong-password
